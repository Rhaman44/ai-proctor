# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# Cloudinary (used to store violation screenshots)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=add-your-cloud-name
CLOUDINARY_API_KEY=add-your-api-key
CLOUDINARY_API_SECRET=add-your-api-secret

# Firebase Admin SDK
# Download serviceAccountKey.json from:
# Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Save it in the project root (it's gitignored) or set a custom path here:
FIREBASE_SERVICE_ACCOUNT_KEY=serviceAccountKey.json
