// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /students/{id} {
      allow read: if true;  
    }

    match /violations/{violationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}

