{
  "manifest_version": 3,
  "name": "ProctorAI Monitor",
  "version": "2.0.0",
  "description": "AI exam proctoring — student login, tab switch, audio monitoring",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "optional_permissions": ["microphone"],
  "host_permissions": [
    "http://localhost:8765/*",
    "ws://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
